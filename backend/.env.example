# ─────────────────────────────────────────
# UniResolve — Environment Configuration
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# MongoDB connection string
# Local:  mongodb://localhost:27017/uniresolve
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/uniresolve
MONGO_URI=mongodb://localhost:27017/uniresolve

# JWT secret key — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret_string_in_production

# JWT token expiry
JWT_EXPIRES_IN=7d

# Port the server listens on
PORT=5000

# Node environment: development | production
NODE_ENV=development
